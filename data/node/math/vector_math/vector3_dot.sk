# ===================== #
# Chip: Vector3 Dot
# Last Modified: 2026 04 18 18:28
# Created: 2026 04 18 18:28
# ===================== #

# ===================== #
# Circuit Data
# ===================== #
# Inputs
# 1 (LHS) (static) [ vector ] (min n/a, max n/a)
# 2 (RHS) (static) [ vector ] (min n/a, max n/a)
# -------------------- #
# Outputs
# 1 (Result) (static) [ float ] (min n/a, max n/a)
# ===================== #

on load:
    add 1 to {DEV_CHIP_COUNT}

variables:
    {_version} = "1.0.0"
    {_execution} = "port1"

function CHIP_vector3_dot(port1: object, port2: object):
    if port1 is None or port2 is None:

        return "TRIGGER.ERROR.PORT.EMPTY_VALUE"

    else if not hasattr(port1, "dot") or not hasattr(port2, "dot"):

        return "TRIGGER.ERROR.PORT.INVALID_TYPE"

    return port1.dot(port2)
