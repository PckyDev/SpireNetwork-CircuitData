# ===================== #
# Chip: API Get
# Last Modified: 2026 04 23 00:00
# Created: 2026 04 22 22:04
# ===================== #

# ===================== #
# Circuit Data
# ===================== #
# Inputs
# 1 (trigger) (static) [ exec ] (min n/a, max n/a)
# 2 (URL) (static) [ string ] (min n/a, max n/a)
# 3 (Data) (static) [ list<string> ] (min n/a, max n/a)
# 4 (Headers) (static) [ list<string> ] (min n/a, max n/a)
# 5 (Parameters) (static) [ list<string> ] (min n/a, max n/a)
# 6 (auth) (static) [ string ] (min n/a, max n/a)
# -------------------- #
# Outputs
# 1 (Run) (static) [ exec ] (min n/a, max n/a)
# 2 (On Response) (static) [ exec ] (min n/a, max n/a)
# 3 (Success) (static) [ bool ] (min n/a, max n/a)
# 4 (Response Code) (static) [ int ] (min n/a, max n/a)
# 5 (Data) (static) [ any ] (min n/a, max n/a)
# ===================== #

on load:
    add 1 to {DEV_CHIP_COUNT}

variables:
    {_version} = "1.0.0"
    {_execution} = "port1"
    {chip_success} = false
    {chip_response_code} = 0
    {chip_response_data} = ""

function _CHIP_api_get_validate_string_list(value: object):

    if value is None:

        return None

    if not isinstance(value, list):

        return "TRIGGER.ERROR.PORT.INVALID_TYPE"

    for entry in value:

        if not isinstance(entry, str):

            return "TRIGGER.ERROR.PORT.INVALID_TYPE"

    return None


function CHIP_api_get(port2: object, port3: object, port4: object, port5: object, port6: object):

    if port2 is None:

        return "TRIGGER.ERROR.PORT.EMPTY_VALUE"

    else if not isinstance(port2, str):

        return "TRIGGER.ERROR.PORT.INVALID_TYPE"

    else if port2.strip() is "":

        return "TRIGGER.ERROR.PORT.INVALID_VALUE"

    _data_validation = _CHIP_api_get_validate_string_list(port3)

    if _data_validation is not None:

        return _data_validation

    _headers_validation = _CHIP_api_get_validate_string_list(port4)

    if _headers_validation is not None:

        return _headers_validation

    _parameters_validation = _CHIP_api_get_validate_string_list(port5)

    if _parameters_validation is not None:

        return _parameters_validation

    if port6 is not None and not isinstance(port6, str):

        return "TRIGGER.ERROR.PORT.INVALID_TYPE"

    set {_request_url} to "%port2%"

    if port5 is not None:

        if size of port5 > 0:

            set {_request_url} to "%port2%?%join port5 with \"&\"%"

    set {_request_body} to ""
    set {_auth_header} to ""

    if port3 is not None:

        if size of port3 > 0:

            set {_request_body} to join port3 with "&"

    if port6 is not None:

        set {_auth_header} to port6

    if port6 is not None and port6.strip() is not "":

        if {_request_body} is not "":

            http request builder stored in {_request}:
                url: {_request_url}
                method: "GET"
                body: {_request_body}
                timeout: 30 seconds
                headers:
                    Authorization: {_auth_header}
                    Content-Type: application/x-www-form-urlencoded

        else:

            http request builder stored in {_request}:
                url: {_request_url}
                method: "GET"
                timeout: 30 seconds
                headers:
                    Authorization: {_auth_header}

    else if {_request_body} is not "":

        http request builder stored in {_request}:
            url: {_request_url}
            method: "GET"
            body: {_request_body}
            timeout: 30 seconds
            headers:
                Content-Type: application/x-www-form-urlencoded

    else:

        http request builder stored in {_request}:
            url: {_request_url}
            method: "GET"
            timeout: 30 seconds

    send request using {_request}

    set {_response} to last response
    set {_response_code_local} to status code of {_response}
    set {_response_data_local} to body of {_response}
    set {_success_local} to false

    if {_response_code_local} >= 200:

        if {_response_code_local} < 300:

            set {_success_local} to true

    _response_code = {_response_code_local}
    _response_data = {_response_data_local}
    _success = {_success_local}

    return "port2"
